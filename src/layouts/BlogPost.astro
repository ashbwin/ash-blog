---
import PostContent from '../components/PostContent.astro';
import AuthorCard from '../components/Cards/AuthorCard.astro';
import TableOfContents from '../components/TableOfContents.svelte';
import BasicLayout from './BasicLayout.astro';

import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { author as authorConfig } from '../config';
import { dropdown } from '../utils/transition';
import BlogPosting from '../components/json-ld/BlogPosting.astro';

export type Props = {
  post: CollectionEntry<'blog'>;
};

const { coverImage, author: postAuthor, title } = Astro.props.post.data;

const author = postAuthor ?? authorConfig.defaultAuthor;

const { headings } = await render(Astro.props.post);

const layoutProps = {
  coverImage,
  head: {
    titleText: title,
    type: 'article',
    post: Astro.props.post,
  },
} satisfies Parameters<typeof BasicLayout>[0];
---

<BasicLayout {...layoutProps}>
  <Fragment slot="head-extra">
    <BlogPosting post={Astro.props.post} />
  </Fragment>

  <Fragment slot="major">
    <main transition:animate={dropdown()} class="card article-content-card">
      <PostContent post={Astro.props.post} />
    </main>
  </Fragment>

  <Fragment slot="aside">
    {author && <AuthorCard transition:name="author-card" authorId={author} />}
    <div class="toc-card card">
      <TableOfContents headings={headings} client:only />
    </div>
  </Fragment>
</BasicLayout>

<style lang="stylus">
  :global(.page:has(.cover-image) .article-content-card) {
    margin-top: calc(-1.5rem - 64px);
  }

  :global(.page aside) {
    gap: 32px;
  }

  .article-content-card {
    padding: 32px;

    @media (max-width: 1024px) {
      padding: 20px 16px;
    }
  }

  .toc-card {
    position: sticky;
    top: 10vh;
    max-height: 80vh;
    overflow: auto;
  }
</style>
