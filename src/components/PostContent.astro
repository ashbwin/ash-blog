---
import MarkdownWrapper from './MarkdownWrapper.astro';
import Heimu from './Heimu.astro';

import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { processPost } from '../server/utils';
import TimeMeta from './MetaWidgets/TimeMeta.astro';
import TagsMeta from './MetaWidgets/TagsMeta.astro';
import Meta from './MetaWidgets/Meta.astro';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const { category, description, title, tags } = post.data;

const { updateDate, pubDate } = processPost(post);

const { Content, headings } = await render(post);

const customComponents = {
  Heimu,
};
---

<div class="post-content">
  <h1 data-transite-from-title class="article-title">{title}</h1>
  <div class="metas">
    <TimeMeta icon="mdi:calendar-outline" time={pubDate} />
    <TimeMeta icon="mdi:calendar-edit-outline" time={updateDate} />
    <Meta icon="mdi:category-outline" content={category} />
    <TagsMeta tags={tags} />
  </div>
  <br />
  {description?.trim() && <div class="description">描述：{description}</div>}
  <hr />
  <MarkdownWrapper>
    <Content components={customComponents} />
  </MarkdownWrapper>
</div>

<style lang="stylus">
  .post-content {
    .article-title {
      margin: 0.5rem 0;
      font-size: 2.5rem;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    hr {
      margin: 24px -8px
      border-style: dashed;
      opacity: 0.5;
    }

    .metas {
      color: var(--text);
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
    }

    .tag {
      border-radius: 6px;
      padding: 4px 8px;
      background-color: var(--primary-container);
      color: var(--on-primary-container);
      font-size: 0.85rem;
      font-weight: 500;
    }

    .description {
      margin-top: 16px;
      color: var(--text-muted);
      font-style: italic;
      line-height: 1.6;
    }
  }
</style>
