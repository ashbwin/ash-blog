---
import { site, author as authorConfig } from '../config';
import { getDefaultAuthor } from '../utils/configtool';

import type { CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { license: frontmatterLicense, author: postAuthor } = post.data;

// Resolve license: frontmatter > global default > none
let license: { name: string; url: string } | false | undefined;

if (frontmatterLicense === false) {
  license = false;
} else if (typeof frontmatterLicense === 'string') {
  license = site.licensePresets[frontmatterLicense];
} else if (frontmatterLicense && typeof frontmatterLicense === 'object') {
  license = frontmatterLicense;
} else if (site.defaultLicense) {
  license = site.licensePresets[site.defaultLicense];
}

// Resolve author name
const authorName =
  postAuthor ??
  authorConfig.authors[authorConfig.defaultAuthor ?? '']?.name ??
  getDefaultAuthor()?.name;

const postUrl = Astro.url.href;
---

{
  license !== false && license && (
    <div class="copyright-notice">
      <div class="copyright-header">
        <Icon src="mingcute:copyright-line" width="18" height="18" />
        <span>版权声明</span>
      </div>
      <div class="copyright-content">
        {authorName && (
          <p>
            本文由 <strong>{authorName}</strong> 原创，采用{' '}
            <a href={license.url} target="_blank" rel="noopener noreferrer">
              {license.name}
            </a>
            {' 许可协议'}
          </p>
        )}
        {!authorName && (
          <p>
            本文采用{' '}
            <a href={license.url} target="_blank" rel="noopener noreferrer">
              {license.name}
            </a>
            {' 许可协议'}
          </p>
        )}
        <p class="permalink">
          <Icon src="mingcute:link-line" width="16" height="16" />
          <span>原文链接：</span>
          <a href={postUrl}>{postUrl}</a>
        </p>
      </div>
    </div>
  )
}

<style lang="stylus">
  .copyright-notice {
    margin-top: 32px;
    padding: 0;
    border-radius: 12px;
    background-color: var(--secondary-container);
    color: var(--on-secondary-container);
    overflow: hidden;
    border-left: 3px solid var(--primary);
    border: 1px solid var(--border);

    .copyright-header {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      background-color: var(--primary-container);
      color: var(--on-primary-container);
      font-weight: 600;
      font-size: 0.95rem;

      :global(.icon) {
        opacity: 0.8;
      }
    }

    .copyright-content {
      padding: 16px 20px;
      font-size: 0.9rem;
      line-height: 1.7;

      p {
        margin: 0 0 12px 0;

        &:last-child {
          margin-bottom: 0;
        }
      }

      strong {
        color: var(--primary);
        font-weight: 600;
      }

      a {
        color: var(--primary);
        text-decoration: none;
        transition: opacity 0.2s ease;

        &:hover {
          opacity: 0.7;
          text-decoration: underline;
        }
      }

      .permalink {
        display: flex;
        align-items: center;
        gap: 6px;
        word-break: break-all;
        font-size: 0.85rem;
        color: var(--text-muted);

        :global(.icon) {
          flex-shrink: 0;
          opacity: 0.7;
        }

        span {
          flex-shrink: 0;
        }

        a {
          color: var(--primary);
          word-break: break-all;
        }
      }
    }
  }
</style>
