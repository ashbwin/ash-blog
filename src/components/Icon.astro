---
import { loadIconSvg } from '../server/icon-loader';

export interface Props {
  src: string;
  [key: string]: string;
}

const { src } = Astro.props;
const { attribs, body } = await loadIconSvg(src);

const mergedAttributes = {
  ...attribs,
  ...Object.fromEntries(
    Object.entries(Astro.props).filter(([key]) => key !== 'src'),
  ),
};
---

<svg {...mergedAttributes} set:html={body} />
